@page "/account/set-password"
@model MyApp.AuthService.Pages.Account.SetPasswordModel

<link rel="stylesheet" href="~/css/auth-pages.css" />

<div class="auth-page auth-page-set-password">
    <section class="auth-card auth-card-set-password" aria-labelledby="set-password-title">
        <h1 id="set-password-title">Set your password</h1>
        <p class="auth-subtitle">Create a password to finish activating your account.</p>

        <form method="post" asp-page="SetPassword" class="auth-form">
            <input asp-for="Token" type="hidden" />

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" type="password" class="auth-input" autocomplete="new-password" />
                <span asp-validation-for="Password" class="field-validation"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" type="password" class="auth-input" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="field-validation"></span>
            </div>

            <span asp-validation-summary="All" class="form-validation"></span>
            <button type="submit" class="auth-button">Set password</button>
        </form>
    </section>
</div>
