@page "/requests"
@rendermode InteractiveServer
@inject MonitoringEventService MonitoringEventService
@inject NavigationManager NavigationManager
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client
@using MyApp.MonitoringService.Hubs

<PageTitle>Request Traces</PageTitle>

<div class="dashboard-page">
    <div class="dashboard-header">
        <div>
            <p class="eyebrow">Request tracing</p>
            <h1>HTTP request logs</h1>
            <p class="lead text-muted">Inspect recent requests, latency, response codes, and failures in one place.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <div class="alert alert-danger" role="alert">
            @_loadError
        </div>
    }

    @if (_snapshot is null)
    {
        <div class="dashboard-loading">
            <div class="spinner-border text-primary" role="status"></div>
            <span>Loading request traces...</span>
        </div>
    }
    else
    {
        <div class="summary-grid">
            <section class="summary-card">
                <span class="summary-label">Error rate (5 min)</span>
                <strong>@_snapshot.ErrorRateLast5MinPct.ToString("0.#")%</strong>
                <span>Of all recent requests</span>
            </section>
            <section class="summary-card">
                <span class="summary-label">Last 24 hours</span>
                <strong>@_snapshot.RequestsLast24Hours</strong>
                <span>Recent traffic</span>
            </section>
            <section class="summary-card">
                <span class="summary-label">Server errors (24h)</span>
                <strong>@_snapshot.ErrorResponsesLast24Hours</strong>
                <span>5xx responses</span>
            </section>
            <section class="summary-card">
                <span class="summary-label">Avg duration (24h)</span>
                <strong>@_snapshot.AvgDurationMsLast24Hours.ToString("0.##") ms</strong>
                <span>Server-side timing</span>
            </section>
        </div>

        <div class="filter-bar">
            <button class="btn btn-sm @(_filter is null ? "btn-secondary" : "btn-outline-secondary")"
                    @onclick="() => SetFilter(null)">
                All
                <span class="badge text-bg-light ms-1">@_snapshot.Requests.Count</span>
            </button>
            <button class="btn btn-sm @(_filter == "Success" ? "btn-success" : "btn-outline-success")"
                    @onclick='() => SetFilter("Success")'>
                Success
                <span class="badge text-bg-light ms-1">@CountByLabel("Success")</span>
            </button>
            <button class="btn btn-sm @(_filter == "Client Error" ? "btn-warning" : "btn-outline-warning")"
                    @onclick='() => SetFilter("Client Error")'>
                Client Error
                <span class="badge text-bg-light ms-1">@CountByLabel("Client Error")</span>
            </button>
            <button class="btn btn-sm @(_filter == "Server Error" ? "btn-danger" : "btn-outline-danger")"
                    @onclick='() => SetFilter("Server Error")'>
                Server Error
                <span class="badge text-bg-light ms-1">@CountByLabel("Server Error")</span>
            </button>

            <div class="trace-filter input-group input-group-sm">
                <span class="input-group-text">Trace ID</span>
                <input class="form-control"
                       placeholder="Search Trace ID"
                       @bind="_traceIdFilter"
                       @bind:event="oninput" />
                @if (HasTraceIdFilter)
                {
                    <button class="btn btn-outline-secondary" type="button" @onclick="ClearTraceIdFilter">Clear</button>
                }
            </div>
        </div>

        @if (!FilteredRequests.Any())
        {
            <div class="empty-state card shadow-sm border-0">
                <div class="card-body">
                    <h2>@GetEmptyStateTitle()</h2>
                    <p class="text-muted mb-0">@GetEmptyStateDescription()</p>
                </div>
            </div>
        }
        else
        {
            <div class="events-list">
                @foreach (var item in FilteredRequests)
                {
                    <article class="event-card card shadow-sm border-0">
                        <div class="card-body">
                            <div class="event-card__header">
                                <div>
                                    <div class="event-badges">
                                        <span class="badge @GetStatusLabelBadgeClass(item.StatusLabel)">@item.StatusLabel</span>
                                        <span class="badge text-bg-light">@item.Method</span>
                                        <span class="badge @(GetStatusCodeBadgeClass(item.StatusCode))">@item.StatusCode</span>
                                    </div>
                                    <h2>@item.Path</h2>
                                    @if (!string.IsNullOrWhiteSpace(item.QueryString))
                                    {
                                        <p class="text-muted mb-0 query-string"><code>@item.QueryString</code></p>
                                    }
                                </div>
                                <div class="event-meta text-muted">
                                    <div><strong>ID:</strong> @item.TraceEntryId</div>
                                    <div><strong>Time:</strong> @item.TimestampUtc.ToLocalTime().ToString("g")</div>
                                    <div><strong>Duration:</strong> @item.DurationMs.ToString("0.##") ms</div>
                                </div>
                            </div>

                            <div class="event-details-grid">
                                <div>
                                    <span class="detail-label">User</span>
                                    <div>@(item.UserId ?? "—")</div>
                                </div>
                                <div>
                                    <span class="detail-label">Trace ID</span>
                                    <div><code>@item.TraceId</code></div>
                                </div>
                                <div>
                                    <span class="detail-label">User Agent</span>
                                    <div class="request-user-agent">@(item.UserAgent ?? "—")</div>
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(item.ExceptionType) || !string.IsNullOrWhiteSpace(item.ExceptionMessage))
                            {
                                <details class="event-block">
                                    <summary>Exception details</summary>
                                    <pre>@(string.IsNullOrWhiteSpace(item.ExceptionType) ? "Exception" : item.ExceptionType)
@(string.IsNullOrWhiteSpace(item.ExceptionMessage) ? string.Empty : item.ExceptionMessage)</pre>
                                </details>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    }
</div>

@code {
    private MonitoringRequestSnapshot? _snapshot;
    private string? _loadError;
    private string? _filter;
    private string? _traceIdFilter;
    private HubConnection? _hubConnection;

    private bool HasTraceIdFilter => !string.IsNullOrWhiteSpace(_traceIdFilter);

    private IEnumerable<MonitoringRequestListItem> FilteredRequests
    {
        get
        {
            var requests = _snapshot?.Requests.AsEnumerable() ?? Enumerable.Empty<MonitoringRequestListItem>();

            if (!string.IsNullOrWhiteSpace(_filter))
                requests = requests.Where(r => r.StatusLabel == _filter);

            if (HasTraceIdFilter)
            {
                var traceFilter = _traceIdFilter!.Trim();
                requests = requests.Where(r =>
                    !string.IsNullOrWhiteSpace(r.TraceId)
                    && r.TraceId.Contains(traceFilter, StringComparison.OrdinalIgnoreCase));
            }

            return requests;
        }
    }

    private int CountByLabel(string label) =>
        _snapshot?.Requests.Count(r => r.StatusLabel == label) ?? 0;

    private void SetFilter(string? filter) => _filter = filter;

    private void ClearTraceIdFilter() => _traceIdFilter = null;

    private string GetEmptyStateTitle()
    {
        if (_filter is null && !HasTraceIdFilter)
            return "No request traces yet";

        return "No matching request traces";
    }

    private string GetEmptyStateDescription()
    {
        if (_filter is null && !HasTraceIdFilter)
            return "As soon as traffic reaches this service, request traces will appear here.";

        return "Try a different status or Trace ID filter, or wait for new requests to arrive.";
    }

    protected override async Task OnInitializedAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("hubs/monitoring"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On(MonitoringHub.RequestTraceCaptured, async () =>
        {
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loadError = null;

        try
        {
            _snapshot = await MonitoringEventService.GetRequestSnapshotAsync();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load request traces: {ex.Message}";
        }
    }

    private static string GetStatusLabelBadgeClass(string label) => label switch
    {
        "Server Error" => "text-bg-danger",
        "Client Error" => "text-bg-warning",
        _ => "text-bg-success",
    };

    private static string GetStatusCodeBadgeClass(int statusCode)
    {
        return statusCode switch
        {
            >= 500 => "text-bg-danger",
            >= 400 => "text-bg-warning",
            >= 300 => "text-bg-info",
            _ => "text-bg-success",
        };
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }
}
