{
  "Oidc": {
    "Authority": "http://auth-service:8080",
    "Audience": "bank.api"
  },
  "ReverseProxy": {
    "Routes": {
      "AuthRoute": {
        "ClusterId": "authCluster",
        "Match": { "Path": "/auth/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/auth" }]
      },
      "CoreSignalRRoute": {
        "ClusterId": "coreCluster",
        "Match": { "Path": "/core/hubs/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/core" }]
      },
      "CoreRoute": {
        "ClusterId": "coreCluster",
        "Match": { "Path": "/core/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/core" }]
      },
      "CreditRoute": {
        "ClusterId": "creditCluster",
        "Match": { "Path": "/credit/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/credit" }]
      },
      "UserRoute": {
        "ClusterId": "userCluster",
        "Match": { "Path": "/user/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/user" }]
      },
      "SettingsRoute": {
        "ClusterId": "settingsCluster",
        "Match": { "Path": "/settings/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/settings" }]
      }
    },
    "Clusters": {
      "authCluster": {
        "Destinations": {
          "authDestination": { "Address": "http://auth-service:8080/" }
        }
      },
      "coreCluster": {
        "Destinations": {
          "coreDestination": { "Address": "http://core-service:8080/" }
        }
      },
      "creditCluster": {
        "Destinations": {
          "creditDestination": { "Address": "http://credit-service:8080/" }
        }
      },
      "userCluster": {
        "Destinations": {
          "userDestination": { "Address": "http://user-service:8080/" }
        }
      },
      "settingsCluster": {
        "Destinations": {
          "settingsDestination": { "Address": "http://settings-service:8080/" }
        }
      }
    }
  },
  "InternalApiKey": "CHANGE_ME_IN_PRODUCTION"
}
