{
  "ReverseProxy": {
    "Routes": {
      "CoreRoute": {
        "ClusterId": "coreCluster",
        "Match": {
          "Path": "/core/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/core"
          }
        ]
      },
      "CreditRoute": {
        "ClusterId": "creditCluster",
        "Match": {
          "Path": "/credit/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/credit"
          }
        ]
      },
      "UserRoute": {
        "ClusterId": "userCluster", 
        "Match": {
          "Path": "/user/{**catch-all}"
        }, 
        "Transforms": [
          {
            "PathRemovePrefix": "/user"
          }
        ]
      },
      "WebSettingsRoute": {
        "ClusterId": "webSettingsCluster",
        "Match": {
          "Path": "/web-app-settings/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/web-app-settings"
          }
        ]
      },
      "MobileSettingsRoute": {
        "ClusterId": "mobileSettingsCluster",
        "Match": {
          "Path": "/mobile-app-settings/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/mobile-app-settings"
          }
        ]
      }
    },
    "Clusters": {
      "coreCluster": {
        "Destinations": {
          "coreDestination": {
            "Address": "http://localhost:5208/"
          }
        }
      },
      "creditCluster": {
        "Destinations": {
          "creditDestination": {
            "Address": "http://localhost:5115/"
          }
        }
      },
      "userCluster": {
        "ClusterId": "userCluster",
        "Destinations": {
          "userDestination": {
            "Address": "http://localhost:5004/"
          }
        }
      },
      "webSettingsCluster": {
        "ClusterId": "webSettingsCluster",
        "Destinations": {
          "userDestination": {
            "Address": "http://localhost:5225/"
          }
        }
      },
      "mobileSettingsCluster": {
        "ClusterId": "mobileSettingsCluster",
        "Destinations": {
          "userDestination": {
            "Address": "http://localhost:5226/"
          }
        }
      }
    }
  },
  "InternalApiKey": "CHANGE_ME_IN_PRODUCTION",
  "Jwt": {
    "Issuer": "durrex-bank-user-service",
    "Audience": "durrex-bank",
    "ExpiresInMinutes": 120,
    "KeysPath": "keys"
  }
}