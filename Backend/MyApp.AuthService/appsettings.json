{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=durrex_auth;Username=postgres;Password=postgres"
  },
  "IdentityServer": {
    "IssuerUri": "https://swagor-time.ru/services/auth",
    "IdentityResources": [
      {
        "Name": "openid",
        "Required": true,
        "UserClaims": ["sub"]
      },
      {
        "Name": "profile",
        "UserClaims": ["name", "family_name", "given_name", "preferred_username", "email", "updated_at"]
      },
      {
        "Name": "bank_role",
        "DisplayName": "Bank Role",
        "UserClaims": ["role"]
      }
    ],
    "ApiScopes": [
      {
        "Name": "bank.api",
        "DisplayName": "Durrex Bank API"
      }
    ],
    "ApiResources": [
      {
        "Name": "bank.api",
        "DisplayName": "Durrex Bank API",
        "Scopes": ["bank.api"]
      }
    ],
    "Clients": [
      {
        "ClientId": "web-spa",
        "ClientName": "Durrex Web SPA",
        "AllowedGrantTypes": ["authorization_code"],
        "RequirePkce": true,
        "RequireClientSecret": false,
        "RedirectUris": ["https://swagor-time.ru/callback"],
        "PostLogoutRedirectUris": ["https://swagor-time.ru"],
        "AllowedCorsOrigins": ["https://swagor-time.ru"],
        "AllowedScopes": ["openid", "profile", "bank_role", "bank.api"],
        "AllowOfflineAccess": true,
        "RefreshTokenUsage": "ReUse",
        "RefreshTokenExpiration": "Sliding",
        "SlidingRefreshTokenLifetime": 604800,
        "AccessTokenLifetime": 3600
      },
      {
        "ClientId": "employee-spa",
        "ClientName": "Durrex Employee Portal",
        "AllowedGrantTypes": ["authorization_code"],
        "RequirePkce": true,
        "RequireClientSecret": false,
        "RedirectUris": ["https://swagor-time.ru/callback"],
        "PostLogoutRedirectUris": ["https://swagor-time.ru"],
        "AllowedCorsOrigins": ["https://swagor-time.ru"],
        "AllowedScopes": ["openid", "profile", "bank_role", "bank.api"],
        "AllowOfflineAccess": true,
        "AccessTokenLifetime": 3600
      },
      {
        "ClientId": "mobile-app",
        "ClientName": "Durrex Mobile",
        "AllowedGrantTypes": ["authorization_code"],
        "RequirePkce": true,
        "RequireClientSecret": false,
        "RedirectUris": ["durrex://callback"],
        "AllowedScopes": ["openid", "profile", "bank_role", "bank.api"],
        "AllowOfflineAccess": true,
        "AccessTokenLifetime": 3600
      }
    ]
  },
  "Services": {
    "UserService": "http://user-service:8080"
  },
  "InternalApiKey": "dev-internal-api-key-12345",
  "AdminPassword": "Admin123",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Duende.IdentityServer": "Debug"
    }
  }
}
