@page
@model MyApp.AuthService.Pages.Account.LoginModel

<link rel="stylesheet" href="~/css/auth-pages.css" />

<div class="auth-page auth-page-login">
    <section class="auth-card auth-card-login" aria-labelledby="login-title">
        <h1 id="login-title">Sign in</h1>
        <p class="auth-subtitle">Use your account credentials to continue.</p>

        <form method="post" asp-page="Login" class="auth-form">
            <div class="form-group">
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" type="email" class="auth-input" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="field-validation"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password"></label>
                <input asp-for="Input.Password" type="password" class="auth-input" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="field-validation"></span>
            </div>

            <input asp-for="ReturnUrl" type="hidden" />
            <span asp-validation-summary="All" class="form-validation"></span>

            <button type="submit" class="auth-button">Sign in</button>
        </form>
    </section>
</div>
