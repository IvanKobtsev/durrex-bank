# Copy this file to Backend/.env and set strong secret values.
# Docker Compose automatically loads variables from Backend/.env.

POSTGRES_PASSWORD=change_me_strong_postgres_password
RABBITMQ_DEFAULT_PASS=change_me_strong_rabbitmq_password
AUTH_ADMIN_PASSWORD=change_me_strong_admin_password

# Path to your Firebase service account JSON on the host machine.
# Download it from Firebase Console → Project Settings → Service accounts → Generate new private key.
# Never commit the actual credentials file to the repository.
FIREBASE_CREDENTIALS_PATH=/path/to/your/firebase-credentials.json

